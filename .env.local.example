# Salin file ini jadi .env.local dan isi dengan value asli dari dashboard Supabase.
# JANGAN pernah isi value asli di sini atau di file yang ke-commit ke git.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dipakai nanti di step API parsing (F1)
GEMINI_API_KEY=

# Dipakai nanti untuk proteksi endpoint yang dipanggil iPhone Shortcut (F1, keamanan)
SHORTCUT_API_SECRET=

# Email akun pemilik app — dipakai /api/shortcut supaya selalu nyasar ke akun
# ini walau sudah banyak user lain daftar lewat halaman Sign Up
APP_OWNER_EMAIL=

# VAPID keys untuk Web Push (F8) — generate dengan: node -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Secret untuk proteksi endpoint cron pengecek reminder (dipanggil Vercel Cron)
CRON_SECRET=
